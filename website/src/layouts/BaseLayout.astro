---
import "~/styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Valaris — agentic software factory",
  description = "Valaris is the agentic software factory platform: research, plan, build, review, and ship software with multi-role AI agents.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b0d10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-bg text-fg antialiased">
    <slot />
  </body>
</html>
