---
import { Font } from "astro:assets";
import "~/styles/global.css";
import SEO from "~/components/SEO.astro";

type Props = {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
};

const {
  title,
  description,
  canonical,
  image,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0d10" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      noindex={noindex}
    />

    <Font cssVariable="--font-inter" preload />

    {/* Applied before paint: prevents FOUC by setting data-theme on <html>
        based on stored preference, falling back to prefers-color-scheme. */}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const preferred =
            stored === "dark" || stored === "light"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.setAttribute("data-theme", preferred);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg text-fg antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-white focus:shadow-lg focus:outline-none"
    >
      Skip to content
    </a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
