---
import MobileMenu from "~/components/MobileMenu";

type NavLink = {
  label: string;
  href: string;
};

type Props = {
  links?: ReadonlyArray<NavLink>;
  ctaText?: string;
  ctaHref?: string;
};

const DEFAULT_LINKS: ReadonlyArray<NavLink> = [
  { label: "Product", href: "/product" },
  { label: "Solutions", href: "/solutions" },
  { label: "Docs", href: "/docs" },
  { label: "Pricing", href: "/pricing" },
  { label: "Company", href: "/company" },
];

const {
  links = DEFAULT_LINKS,
  ctaText = "Request a demo",
  ctaHref = "/demo",
} = Astro.props;
---

<header
  class="topnav sticky top-0 z-40 border-b border-[color:var(--color-border)] bg-[color:var(--color-bg)]/90 backdrop-blur supports-[backdrop-filter]:bg-[color:var(--color-bg)]/75"
  data-topnav
>
  <div
    class="topnav__inner mx-auto flex w-full max-w-6xl items-center justify-between px-6 transition-[padding] duration-200 lg:px-8"
  >
    <div class="flex items-center gap-8">
      <slot name="logo">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-md text-sm font-semibold tracking-tight text-[color:var(--color-fg)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[color:var(--color-accent)]"
          aria-label="Valaris — home"
        >
          <span
            aria-hidden="true"
            class="inline-block h-6 w-6 rounded-md bg-[color:var(--color-accent)]"
          ></span>
          <span>Valaris</span>
        </a>
      </slot>

      <nav aria-label="Primary" class="hidden md:block">
        <slot name="links">
          <ul class="flex items-center gap-6">
            {
              links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-[color:var(--color-muted)] transition-colors hover:text-[color:var(--color-fg)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[color:var(--color-accent)]"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </slot>
      </nav>
    </div>

    <div class="flex items-center gap-3">
      <slot name="cta">
        <a
          href={ctaHref}
          class="hidden items-center justify-center rounded-lg bg-[color:var(--color-accent)] px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:brightness-110 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)] md:inline-flex"
        >
          {ctaText}
        </a>
      </slot>

      <MobileMenu
        client:load
        links={links}
        ctaText={ctaText}
        ctaHref={ctaHref}
      />
    </div>
  </div>
</header>

<style>
  /* Condensed-on-scroll: full height at top, shorter when scrolled.
     Pure CSS via scroll-driven animations (Chrome/Edge 115+, FF 125+).
     Without support: falls back to always-full height via the base padding. */
  .topnav__inner {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  @supports (animation-timeline: scroll()) {
    .topnav__inner {
      animation: topnav-condense linear both;
      animation-timeline: scroll(root block);
      animation-range: 0 120px;
    }

    @keyframes topnav-condense {
      from {
        padding-top: 1rem;
        padding-bottom: 1rem;
      }
      to {
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
      }
    }
  }

  /* JS-driven fallback toggle for browsers without scroll-driven animations.
     The inline script below adds `is-condensed` once the user has scrolled. */
  .topnav__inner.is-condensed {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .topnav__inner {
      transition: none;
    }
  }
</style>

<script>
  // Progressive enhancement: only runs when the browser lacks scroll-driven
  // animation support. Adds/removes `is-condensed` based on scroll position.
  // If JS is disabled, the nav stays at the full (comfortable) height — still
  // fully usable, just not condensed.
  (() => {
    if (CSS.supports?.("animation-timeline: scroll()")) return;

    const inner = document.querySelector<HTMLElement>(
      "[data-topnav] .topnav__inner",
    );
    if (!inner) return;

    const CONDENSE_AT = 24;
    const update = (): void => {
      const scrolled = window.scrollY > CONDENSE_AT;
      inner.classList.toggle("is-condensed", scrolled);
    };

    update();
    window.addEventListener("scroll", update, { passive: true });
  })();
</script>
