---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Valaris — agentic software factory"
  description="Valaris is the agentic software factory platform: research, plan, build, review, and ship software with multi-role AI agents."
>
  <section
    class="flex min-h-screen flex-col items-center justify-center px-6 text-center"
  >
    <p
      class="font-mono text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)]"
    >
      Valaris
    </p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
      Valaris — coming soon
    </h1>
    <p class="mt-4 max-w-xl text-base text-[color:var(--color-muted)]">
      An agentic software factory. Research, plan, build, review, and ship —
      multi-role AI agents working from one shared board.
    </p>
  </section>
</BaseLayout>
